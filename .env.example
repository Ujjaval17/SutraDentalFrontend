# Copy to .env.local and adjust, or edit .env.development / .env.production
REACT_APP_API_URL=http://localhost:5000
# Canonical site URL for SEO (sitemap, Open Graph, JSON-LD)
REACT_APP_SITE_URL=https://www.sutradental.com
# Your Google Business Profile URL (critical for local rankings)
REACT_APP_GOOGLE_BUSINESS_URL=https://g.page/r/YOUR-GOOGLE-BUSINESS-ID
REACT_APP_GOOGLE_MAPS_URL=https://maps.google.com/?q=Sutra+Dental+Chandkheda+Ahmedabad
